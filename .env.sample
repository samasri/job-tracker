# Path to Chromium binary used by cmd/screenshots.
# Required if `chromium` is not in PATH (e.g. a locally downloaded binary).
# CHROMIUM_PATH=~/dev/chromium

# Server configuration (all optional, shown with defaults)
# JOBTRACKER_REPO_ROOT=.
# JOBTRACKER_DB_PATH=db/index.sqlite
# JOBTRACKER_ADDR=127.0.0.1:8080
